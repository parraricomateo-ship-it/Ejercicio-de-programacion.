# Clase Vehiculo
class Vehiculo:

    def __init__(self, marca, modelo, velocidad_maxima):
        self.marca = marca
        self.modelo = modelo
        self.velocidad_maxima = velocidad_maxima
        self.velocidad_actual = 0

    # Acelerar el vehículo
    def acelerar(self, incremento):
        if self.velocidad_actual + incremento > self.velocidad_maxima:
            self.velocidad_actual = self.velocidad_maxima
        else:
            self.velocidad_actual += incremento
        print("Velocidad actual:", self.velocidad_actual, "km/h")

    # Frenar el vehículo
    def frenar(self, decremento):
        if self.velocidad_actual - decremento < 0:
            self.velocidad_actual = 0
        else:
            self.velocidad_actual -= decremento
        print("Velocidad actual:", self.velocidad_actual, "km/h")

    # Verificar límite de velocidad
    def verificar_limite(self, velocidad_limite):
        if self.velocidad_actual > velocidad_limite:
            print("⚠️ El vehículo supera el límite de velocidad.")
        else:
            print("✅ El vehículo está dentro del límite permitido.")


# Crear vehículo
vehiculo1 = Vehiculo("Toyota", "Corolla", 200)

# Menú interactivo
while True:
    print("\n--- MENÚ ---")
    print("1. Acelerar")
    print("2. Frenar")
    print("3. Verificar límite de velocidad")
    print("4. Salir")

    opcion = input("Elige una opción: ")

    if opcion == "1":
        inc = int(input("¿Cuánto deseas acelerar? "))
        vehiculo1.acelerar(inc)

    elif opcion == "2":
        dec = int(input("¿Cuánto deseas frenar? "))
        vehiculo1.frenar(dec)

    elif opcion == "3":
        limite = int(input("Ingresa el límite de velocidad: "))
        vehiculo1.verificar_limite(limite)

    elif opcion == "4":
        print("Programa finalizado.")
        break

    else:
        print("Opción no válida.")
